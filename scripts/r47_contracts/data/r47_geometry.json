{
  "dataset": "r47",
  "version": 4,
  "description": "Machine-readable R47 physical-reference geometry plus Android app LCD, chrome, and label contract data.",
  "contract_scope": {
    "role": "complete_r47_physical_and_android_geometry_contract",
    "contains": [
      "reference_frame",
      "real_lcd",
      "measured_key_rows",
      "measured_key_columns",
      "android_app_contract.chrome",
      "android_app_contract.labels"
    ],
    "distinction": {
      "physical_calculator": "reference_frame plus tables",
      "android_app": "android_app_contract"
    }
  },
  "reference_frame": {
    "label": "r47",
    "width": 1820,
    "height": 3403
  },
