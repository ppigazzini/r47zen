        "text_size": 66,
        "x_offset_from_main_key_body_right": 16,
        "y_offset_from_main_key_body_top": 80
      },
      "top_label_solver": {
        "max_shift_fraction": 0.15,
        "min_scale": 0.82,
        "scale_step": 0.06
      }
    }
