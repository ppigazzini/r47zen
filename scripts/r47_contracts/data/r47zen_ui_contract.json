{
  "dataset": "r47zen_ui_contract",
  "version": 1,
  "description": "Machine-readable Android UI geometry and label policy layered on the measured R47 reference canvas.",
  "coordinate_space": "logical_canvas",
  "based_on": {
    "physical_dataset": "r47_physical_geometry",
    "physical_version": 1
  },
  "logical_canvas": {
    "width": 1820,
    "height": 3403
  },
  "chrome": {
    "native_shell_draw_corner_radius": 0,
    "scaled_mode_fit_trim": {
      "left": 48,
      "top": 49,
      "right": 48,
      "bottom": 56
    },
    "settings_strip_tap_height": 242,
    "main_menu_button": {
      "left": 1493,
      "top": 0,
      "width": 242,
      "height": 242
    },
    "lcd_windows": {
      "native": {
        "left": 85,
        "top": 242,
        "width": 1650,
        "height": 990
      }
    },
    "lcd_frame_buffer": {
      "pixel_width": 400,
      "pixel_height": 240
    },
    "non_softkey_view_height": 236
  },
  "overlay_visual_policy": {
    "settings_menu_glyph": {
      "tab_width_to_height_ratio": 1.0,
      "main_menu": {
        "tab_height_dp": 11,
        "gap_dp": 4,
        "bottom_inset_dp": 4
      },
      "onboarding_hint": {
        "tab_height_dp": 18,
        "gap_dp": 6
      }
    },
    "settings_discovery_hint": {
      "colors": {
        "surface_argb": "#EC12151A",
        "on_surface_argb": "#FFF7F3EA",
        "stroke_argb": "#FF8EDAFE",
        "menu_orange_fallback_argb": "#FFFFC36F",
        "menu_blue_fallback_argb": "#FF8EDAFE"
      },
      "card": {
        "outer_margin_dp": 24,
        "min_width_dp": 220,
        "max_width_dp": 360,
        "width_ratio": 0.72,
        "horizontal_padding_dp": 18,
        "vertical_padding_dp": 16,
        "corner_radius_dp": 22,
        "line_spacing_dp": 4,
        "glyph_text_gap_dp": 12
      },
      "stroke": {
        "width_dp": 2.5,
        "extra_width_dp": 1.5,
        "alpha_base": 150,
        "alpha_delta": 105
      },
      "text": {
        "size_dp": 14
      },
      "fill": {
        "alpha_base": 220,
        "alpha_delta": 16
      },
      "pulse": {
        "period_ms": 1400
      }
    },
    "developer_performance_hud": {
      "text": {
        "size_dp": 12,
        "min_available_height_dp": 24,
        "height_ratio": 0.09,
        "min_size_dp": 10,
        "max_size_dp": 16,
        "min_label_width_dp": 48,
        "max_label_horizontal_margin_dp": 8,
        "baseline_bottom_inset_dp": 6,
        "leading_inset_dp": 2
      },
      "shadow": {
        "radius_dp": 2,
        "argb": "#D0000000"
      }
    },
    "touch_zone_debug": {
      "stroke_width_dp": 2,
      "stroke_alpha": 180
    }
  },
  "key_surface": {
    "main_key": {
      "draw_corner_radius": 20,
      "painted_body_width_bonus": 6,
      "painted_body_height": 144,
      "slot_horizontal_bias": 0,
      "slot_vertical_bias": 0
    },
    "softkey": {
      "draw_corner_radius": 20,
      "preview_line_side_inset": 10,
      "preview_line_bottom_inset": 4,
      "value_text_size_ratio": 0.18,
      "value_width_ratio": 0.34,
      "value_right_inset": 7,
      "value_top_inset": 6,
      "overlay_center_right_inset": 10,
      "overlay_center_bottom_inset": 12
    },
    "standard_key": {
      "right_strip_width": 80
    },
    "matrix_key": {
      "right_strip_width": 103
    }
  },
  "label_layout": {
    "primary_legend": {
      "horizontal_anchor": "main_key_body_center",
      "vertical_anchor": "main_key_body_center",
      "horizontal_padding": 12,
      "text_sizes": {
        "default": 76,
        "numeric": 114,
        "shifted": 94
      }
    },
    "top_f_legend": {
      "horizontal_anchor": "shared_top_label_group",
      "vertical_anchor": "shared_top_label_baseline",
      "text_size": 64,
      "horizontal_gap": 10,
      "vertical_lift": 86
    },
    "top_g_legend": {
      "horizontal_anchor": "shared_top_label_group",
      "vertical_anchor": "shared_top_label_baseline",
      "text_size": 64,
      "horizontal_gap": 10,
      "vertical_lift": 86
    },
    "right_side_letter_legend": {
      "horizontal_anchor": "main_key_body_right",
      "vertical_anchor": "main_key_body_top",
      "text_size": 66,
      "x_offset_from_main_key_body_right": 16,
      "y_offset_from_main_key_body_top": 80
    }
  },
  "top_label_solver": {
    "max_shift_fraction": 0.15,
    "min_scale": 0.82,
    "scale_step": 0.06
  }
}
