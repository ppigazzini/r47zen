# R47 local ignore rules

# Local Python environment and caches
/.venv/
__pycache__/
**/__pycache__/
**/*.py[cod]

# Local editor and OS state
/.vscode/
*.code-workspace
/.idea/
*.iml
.DS_Store
._*
.directory
*~
.fuse_hidden*
.nfs*
Thumbs.db
[Dd]esktop.ini

# Android / Gradle local state and build outputs
**/.gradle/
**/.cxx/
**/.externalNativeBuild/
**/build/
**/local.properties
**/*.apk
**/*.aab
**/output-metadata.json
*.hprof
/captures/
*.jks
*.keystore
google-services.json

# Meson / Ninja out-of-source build trees
/build/
/build.sim/
/build.dmcp*/
/build.rel*/
/meson-logs/
/meson-private/
/build.ninja
/.ninja_deps
/.ninja_log
/compile_commands.json

# Native compilation artefacts
**/*.o
**/*.obj
**/*.so

# Local generated binaries, archives, and runtime data
/wp43
/c47
/r47
/testSuite
/generate*
/ttf2RasterFonts
/wp43.exe
/c47.exe
/r47.exe
/testSuite.exe
/generate*.exe
/ttf2RasterFonts.exe
backup.bin
backup.cfg
backupR47.cfg
wp43.sav
wp43.dat
c47.sav
c47.dat
*.s47
*.zip
20*.REGS.TSV
20*.bmp
tags
/SAVFILES/

# Optional local-only roots omitted from the public checkout
/LIBRARY/
/PROGRAMS/
/res/

# Public-checkout upstream hydration contract
/Makefile
/meson.build
/meson_options.txt
/src/
/dep/
/docs/code/meson.build
/subprojects/
/tools/
/upstream.lock

# Android build-only staging and retired legacy native snapshot paths
/android/.staged-native/
/android/app/src/main/cpp/c47/
/android/app/src/main/cpp/decNumberICU/
/android/app/src/main/cpp/generated/
/android/app/src/main/cpp/gmp/
/android/app/src/main/cpp/STAGED-SOURCE-MANIFEST.txt
/android/app/src/main/cpp/staged_native_sources.cmake
