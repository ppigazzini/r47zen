# R47 project rules

# Local maintainer workspace
/__DEV/
/upstream.lock
/.venv/

# Android / Gradle local state and build outputs
**/.gradle/
**/.kotlin/
**/.cxx/
**/.externalNativeBuild/
**/build/
**/local.properties
**/*.apk
**/*.aab
**/output-metadata.json
*.hprof
/captures/
*.jks
*.keystore
google-services.json
**/.lint-run.log
**/.assemble-run.log
**/.help-run.log

# Android build-only staging and retired legacy native snapshot paths
/android/.staged-native/
/android/app/src/main/cpp/c47/
/android/app/src/main/cpp/decNumberICU/
/android/app/src/main/cpp/generated/
/android/app/src/main/cpp/gmp/
/android/app/src/main/cpp/STAGED-SOURCE-MANIFEST.txt
/android/app/src/main/cpp/staged_native_sources.cmake

# Meson / Ninja out-of-source build trees
/build/
/build.sim/
/build.dmcp*/
/build.rel*/
/meson-logs/
/meson-private/
/build.ninja
/.ninja_deps
/.ninja_log
/compile_commands.json

# Native compilation artifacts
**/*.o
**/*.obj
**/*.so

# GitLab C43 upstream overlay
# Ignore every root-level upstream payload, then reopen only repo-owned paths.
/*
!/.github/
!/.gitignore
!/COPYING
!/README.md
!/android/
!/scripts/
!/upstream.source

# General local state

# Python caches
__pycache__/
**/__pycache__/
**/*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Editor and OS state
/.vscode/
*.code-workspace
/.idea/
*.iml
._*
.directory
*~
.fuse_hidden*
.nfs*
